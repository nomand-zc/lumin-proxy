{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "构建 lumin-proxy",
            "type": "shell",
            "command": "go",
            "args": [
                "build",
                "-o",
                "bin/lumin-proxy",
                "./cmd/lumin-proxy"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": "$go"
        },
        {
            "label": "运行 lumin-proxy",
            "type": "shell",
            "command": "go",
            "args": [
                "run",
                "./cmd/lumin-proxy",
                "-c",
                "lumin_proxy.yaml"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "problemMatcher": "$go"
        }
    ]
}