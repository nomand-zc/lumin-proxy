{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "调试 lumin-proxy (启动)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/lumin-proxy",
            "args": [
                "-c",
                "lumin_proxy.yaml"
            ],
            "env": {},
            "cwd": "${workspaceFolder}",
            "showLog": true,
            "logOutput": "rpc",
            "trace": "verbose"
        },
        {
            "name": "调试 lumin-proxy (编译后调试)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/lumin-proxy",
            "args": [
                "-c",
                "lumin_proxy.yaml"
            ],
            "env": {},
            "cwd": "${workspaceFolder}",
            "showLog": true,
            "logOutput": "rpc",
            "trace": "verbose"
        },
        {
            "name": "调试 lumin-proxy (远程调试)",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "remotePath": "${workspaceFolder}",
            "port": 2345,
            "host": "127.0.0.1",
            "showLog": true,
            "logOutput": "rpc",
            "trace": "verbose"
        }
    ]
}